{
  "name": "next-js-boilerplate-postgresql-drizzle",
  "version": "0.1.50",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "preview": "next build && node scripts/start.mjs",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint src --ext .ts,.tsx --cache",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --cache",
    "typecheck": "rm -rf .next/types .next/dev/types && tsc --noEmit",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,json,md,mdx}\"",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,css,json,md,mdx}\"",
    "test": "vitest run",
    "test:integration": "vitest run src/tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pree2e": "pnpm exec playwright install chromium",
    "e2e": "playwright test",
    "e2e:install": "pnpm exec playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/seed.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "db:studio": "drizzle-kit studio",
    "knip": "knip --dependencies -c docs/tools/knip.json",
    "codehawk": "cd docs/tools && codehawk ../../src",
    "docs:check": "node scripts/check-docs.mjs",
    "setup": "node scripts/setup.mjs",
    "check:all": "./scripts/check-all.sh",
    "check:fix": "CHECK_ALL_FIX=1 ./scripts/check-all.sh",
    "clean": "node scripts/clean.mjs",
    "docker:build": "docker build -t next-js-boilerplate-postgresql-drizzle .",
    "docker:run": "docker run --env-file .env.local -p ${PORT:-3000}:${PORT:-3000} next-js-boilerplate-postgresql-drizzle",
    "docker:up": "docker compose up --build",
    "docker:up:db": "docker compose --profile db up --build",
    "docker:down": "docker compose down",
    "prepare": "husky",
    "install:pnpm": "pnpm install --frozen-lockfile"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.53.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.100.14",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "nodemailer": "^8.0.8",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-icons": "^5.6.0",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@storybook/nextjs": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.1.7",
    "codehawk-cli": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{css,json,md,mdx}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "esbuild@<=0.24.2": "0.27.7",
      "postcss@<8.5.10": "8.5.14",
      "vite@>=8.0.0 <=8.0.4": "8.0.13"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-14505"
      ]
    }
  }
}
