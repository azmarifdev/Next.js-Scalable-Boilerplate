# =========================================
# Next.js Boilerplate Environment Template
# =========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit real secrets to Git.

# ---------- Public App Settings ----------
NEXT_PUBLIC_APP_NAME=Next.js-Boilerplate-PostgresQL-Drizzle
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ---------- Runtime Mode ----------
# internal: Next.js API routes are used as backend (default)
# external: frontend talks to an external backend
NEXT_PUBLIC_BACKEND_MODE=internal

# better-auth: built-in auth routes
# custom-auth: external auth provider
NEXT_PUBLIC_AUTH_PROVIDER=better-auth
NEXT_PUBLIC_ENABLE_CUSTOM_AUTH=false
ENABLE_CUSTOM_AUTH=false
NEXT_PUBLIC_CUSTOM_AUTH_BASE_URL=

# ---------- Feature Flags ----------
NEXT_PUBLIC_FEATURE_ECOMMERCE=true
NEXT_PUBLIC_FEATURE_BILLING=true
NEXT_PUBLIC_FEATURE_ADMIN=true

# ---------- Database ----------
# Required for internal backend when ALLOW_DEMO_AUTH=false
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db
DATABASE_URL=

# ---------- Session Security ----------
# Required for internal auth unless ALLOW_INSECURE_DEV_AUTH=true.
# Generate: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Optional key rotation list (comma separated)
AUTH_SESSION_SECRETS=

# ---------- MFA / Step-up Auth ----------
AUTH_MFA_STATIC_CODE=
AUTH_MFA_VERIFY_URL=
AUTH_MFA_VERIFY_BEARER_TOKEN=
ALLOW_STATIC_MFA_IN_PRODUCTION=false
REQUIRE_ADMIN_STEP_UP_AUTH=false

# ---------- Local Development Escape Hatches ----------
# Use only in local development.
ALLOW_DEMO_AUTH=false
ALLOW_INSECURE_DEV_AUTH=false
