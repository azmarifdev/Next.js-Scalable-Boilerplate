# =========================================
# Next.js Boilerplate Environment Template
# =========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit real production secrets to Git.
# In production, set values in your hosting provider's env settings.
# In CI, set values in GitHub Actions Secrets.

# ---------- Public App Settings ----------
# Change these first when adopting the boilerplate.
NEXT_PUBLIC_APP_NAME=Next.js-Boilerplate-PostgresQL-Drizzle

# ---------- Local App Origin ----------
# Local origin is derived as APP_PROTOCOL://APP_HOST:PORT when NEXT_PUBLIC_SITE_URL is blank.
# Change PORT once to move local dev, preview, sitemap, robots, and E2E defaults.
APP_PROTOCOL=http
APP_HOST=localhost
PORT=3000

# Set explicitly in production, or when you need to override the derived local URL.
NEXT_PUBLIC_SITE_URL=

# Leave blank for internal backend mode. Set only when NEXT_PUBLIC_BACKEND_MODE=external.
NEXT_PUBLIC_API_BASE_URL=

# ---------- Runtime Mode ----------
# internal: Next.js API routes are used as backend (default)
# external: frontend talks to an external backend
NEXT_PUBLIC_BACKEND_MODE=internal

# better-auth: built-in auth routes
# custom-auth: external auth provider
NEXT_PUBLIC_AUTH_PROVIDER=better-auth
NEXT_PUBLIC_ENABLE_CUSTOM_AUTH=false
ENABLE_CUSTOM_AUTH=false
NEXT_PUBLIC_CUSTOM_AUTH_BASE_URL=

# ---------- Optional Modules ----------
# Set false if your product will not ship admin-only surfaces.
NEXT_PUBLIC_FEATURE_ADMIN=true

# ---------- Database ----------
# Required for internal backend/auth and runtime DB access.
# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db
#
# Neon runtime example:
# DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/db?sslmode=require&channel_binding=require
DATABASE_URL=

# Optional. Prevent accidental production seeding.
ALLOW_DB_SEED=false

# Optional. Prevent accidental production resets.
ALLOW_DB_RESET=false

# ---------- Session Security ----------
# Required for internal auth.
# Generate: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Optional key rotation list (comma separated).
AUTH_SESSION_SECRETS=

# Optional. Skip runtime config validation (not recommended).
SKIP_RUNTIME_VALIDATION=false

# ---------- MFA / Step-up Auth ----------
# Keep false until AUTH_MFA_VERIFY_URL points to a real verifier.
REQUIRE_ADMIN_STEP_UP_AUTH=false
AUTH_MFA_VERIFY_URL=
AUTH_MFA_VERIFY_BEARER_TOKEN=

# ---------- Observability ----------
# Optional. Add Sentry values in production for error monitoring.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# ---------- Email ----------
# Optional. Required when you add transactional email flows.
RESEND_API_KEY=
EMAIL_FROM=

# ---------- Rate Limiting ----------
# Optional locally. Recommended in production for shared serverless rate limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- E2E / Seed (local only) ----------
# Optional. Use a disposable test database, never production.
E2E_DATABASE_URL=
E2E_BASE_URL=
# Used by seed script and Playwright auth tests.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=password123
E2E_AUTH_EMAIL=admin@example.com
E2E_AUTH_PASSWORD=password123
